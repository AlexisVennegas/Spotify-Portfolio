---

import Home from '../Icons/Home.astro';
import Search from '../Icons/Search.astro';
---

<div class="navegator">
    <ul>
        <a href="./">
            <li>
                <Home  />
           <p class="nav-text home">Inicio</p>

            </li>
        </a>
            <li class="search-li">
                <Search />
             <p class="nav-text-search">Buscar</p>
                <input class="search-input hidden" type="search" placeholder="Buscar" />
            </li>
     
    </ul>
</div>
<style>
    .nav-text-search {
        text-decoration: none;
        color: rgb(161 161 170);
        font-weight: 500;
        font-size: 17px;
        font-family: 'Poppins', sans-serif;
    }
    .navegator {
		width: 334px;
		height: 120px;
		border-radius: 10px;
		margin: 10px 0 ;
		background-color:#121212;
	}
  
    ul {
        list-style: none;   
        width: 100%;
        cursor: pointer;    
        height: 100%;   
    }

    li {
        display: flex;
        justify-content: flex-start;
        padding: 30px;
        align-items: center;
        width: 95%;
        height: 50%;
    }
    @media  (width < 768px) {
        li {
            justify-content: center;
            padding: 0 !important;
        }    
        
    }
    .search-li {
        position: relative;
    }

    .search-input {
        display: none;
        background-color: transparent;
        color: #fff;
        position: absolute;
        right: 0;
        border: none;
        font-size: 17px;
        font-family: 'Poppins', sans-serif;
        font-weight: 500;
        outline: none;
    }   
    /* quitamos todos los hover con outline o background white al input*/
    .search-input:hover {
        background-color: transparent !important;
        outline: none !important;
    }
   
</style>
<script is:inline>


document.addEventListener('astro:after-swap', () => {
    //const searchLi = document.querySelector('.search-li');
    const searchLi = document.querySelectorAll('.search-li')[0];
    const searchInput = searchLi.querySelector('.search-input');
 
    const searchText = searchLi.querySelector('.nav-text-search');

    searchLi.addEventListener('click', () => {
        searchInput.style.display = 'block';
        searchText.style.display = 'none';
    });

    
    searchInput.addEventListener('keyup', (e) => {
        const term = e.target.value.toLowerCase();
        const listSongs = document.querySelectorAll('.liListsongs');

        listSongs.forEach((song) => {
            const title = song.textContent;
            song.style.display = title.toLowerCase().includes(term) ? 'block' : 'none';
        });
    });
});
</script>